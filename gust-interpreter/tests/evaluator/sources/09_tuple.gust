fun main() {
    // Construction and element access.
    let t = (10, 20);
    assert(t.0 == 10);
    assert(t.1 == 20);
    // Mixed types.
    let pair = (1, true);
    assert(pair.0 == 1);
    assert(pair.1);
    // Nested tuple.
    let nested = (1, (2, 3));
    let inner = nested.1;
    assert(inner.0 == 2);
    assert(inner.1 == 3);
}
