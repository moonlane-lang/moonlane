fun main() {
    // Break only breaks the innermost loop.
    mut outer_ran = 0;
    loop {
        while (true) { break; }
        outer_ran = 1;
        break;
    }
    assert(outer_ran == 1);
    // Each outer iteration starts with a fresh inner scope.
    mut total = 0;
    mut k = 0;
    loop {
        k += 1;
        if (k > 3) { break; }
        mut j = 0;
        loop {
            j += 1;
            if (j >= 2) { break; }
        }
        total += j;
    }
    assert(total == 6);
    // Return propagates through nested loops — must be the last statement.
    loop {
        loop { return; }
        let _never = 1 / 0;
    }
}
