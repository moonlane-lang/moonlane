// ? on Ok unwraps the value; ? on Err propagates out of the calling function.
fun safe_div(a: Int, b: Int) -> Result<Int, Int> {
    if (b == 0) {
        Result::Err { error: -1 }
    } else {
        Result::Ok { value: a / b }
    }
}
// Uses ? internally — if safe_div returns Ok(q), continues with Ok(q+1).
// If safe_div returns Err(e), ? propagates so try_div returns Err(e).
fun try_div(a: Int, b: Int) -> Result<Int, Int> {
    let q = safe_div(a, b)?;
    Result::Ok { value: q + 1 }
}
fun main() {
    // ? on Ok: unwraps, continues, returns Ok(6).
    let r1 = try_div(10, 2);
    match r1 {
        Result::Ok  { value } => assert(value == 6),
        Result::Err { error } => assert_msg(false, "expected Ok"),
    };
    // ? on Err: propagates, try_div returns Err(-1).
    let r2 = try_div(10, 0);
    match r2 {
        Result::Ok  { value } => assert_msg(false, "expected Err"),
        Result::Err { error } => assert(error == -1),
    };
}
