fun main() {
    assert(3 + 4   == 7);
    assert(10 - 3  == 7);
    assert(3 * 4   == 12);
    assert(10 / 3  == 3);
    assert(10 % 3  == 1);
    // Division truncates toward zero (not floor).
    assert(7 / 2   == 3);
    assert(-7 / 2  == -3);
    // Remainder sign follows the dividend.
    assert(-10 % 3  == -1);
    assert(10 % -3  == 1);
}
