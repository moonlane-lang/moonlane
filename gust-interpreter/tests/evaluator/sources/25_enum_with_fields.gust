enum Shape { Circle { radius: Int }, Rect { w: Int, h: Int } }

fun main() {
    // Enum variant with fields.
    let circle = Shape::Circle { radius: 5 };
    let r = match circle {
        Shape::Circle { radius } => radius,
        Shape::Rect   { w, h }   => w + h,
    };
    assert(r == 5);
    // Second variant.
    let rect = Shape::Rect { w: 3, h: 4 };
    let area = match rect {
        Shape::Circle { radius } => radius,
        Shape::Rect   { w, h }   => w * h,
    };
    assert(area == 12);
}
