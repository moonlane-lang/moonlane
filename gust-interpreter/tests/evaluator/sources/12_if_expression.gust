fun main() {
    // True branch.
    let x = if (true) { 1 } else { 2 };
    assert(x == 1);
    // False branch.
    let y = if (false) { 1 } else { 2 };
    assert(y == 2);
    // No-else in statement position — evaluates without error.
    if (false) { };
    // Nested if.
    let z = 5;
    let result = if (z > 0) {
        if (z > 10) { 2 } else { 1 }
    } else {
        0
    };
    assert(result == 1);
}
