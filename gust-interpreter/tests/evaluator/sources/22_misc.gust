let global = 42;

fun main() {
    // Top-level let binding is in scope inside main.
    assert(global == 42);
    // String equality and inequality.
    assert("abc" == "abc");
    assert("abc" != "xyz");
    assert(!("abc" == "xyz"));
    // Bool equality and inequality.
    assert(true  == true);
    assert(false == false);
    assert(true  != false);
    assert(!(true  == false));
}
