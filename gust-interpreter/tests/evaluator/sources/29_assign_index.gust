fun main() {
    // Plain index assignment.
    mut arr = [10, 20, 30];
    arr[1] = 99;
    assert(arr[0] == 10);
    assert(arr[1] == 99);
    assert(arr[2] == 30);
    // Compound index assignment operators.
    arr[0] += 5;
    assert(arr[0] == 15);
    arr[2] *= 2;
    assert(arr[2] == 60);
    // Assignment using a variable as the index.
    mut i = 1;
    arr[i] = 0;
    assert(arr[1] == 0);
}
