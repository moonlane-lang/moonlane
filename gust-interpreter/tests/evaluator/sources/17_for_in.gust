fun main() {
    // Array iteration.
    let arr = [10, 20, 30];
    mut sum = 0;
    for (let x in arr) { sum += x; }
    assert(sum == 60);
    // Exclusive range.
    mut sum2 = 0;
    for (let i in 0..5) { sum2 += i; }
    assert(sum2 == 10);
    // Inclusive range.
    mut sum3 = 0;
    for (let i in 1..=4) { sum3 += i; }
    assert(sum3 == 10);
    // Break stops early.
    mut sum4 = 0;
    for (let x in [1, 2, 3, 4, 5]) {
        if (x == 3) { break; }
        sum4 += x;
    }
    assert(sum4 == 3);
    // Continue skips the current element.
    mut sum5 = 0;
    for (let x in [1, 2, 3, 4, 5]) {
        if (x == 3) { continue; }
        sum5 += x;
    }
    assert(sum5 == 12);
    // Binding does not leak into the outer scope.
    let x = 42;
    mut inner = 0;
    for (let x in [1, 2, 3]) { inner += x; }
    assert(inner == 6);
    assert(x   == 42);
}
