// Returns a closure that closes over a counter, incrementing on each call.
fun make_counter(start: Int) -> fun() -> Int {
    mut n = start;
    fun() -> Int { n += 1; n }
}
// Closure that captures two variables from different outer scopes.
fun make_between(lo: Int, hi: Int) -> fun(Int) -> Bool {
    fun(x: Int) -> Bool { (x >= lo) && (x <= hi) }
}

fun main() {
    // Each call to the closure advances the same captured counter.
    let next = make_counter(0);
    let r1 = next();
    assert(r1 == 1);
    let r2 = next();
    assert(r2 == 2);
    // Two independent counters do not share state.
    let a = make_counter(10);
    let b = make_counter(10);
    assert(a() == 11);
    assert(a() == 12);
    assert(b() == 11);
    // Closure capturing two variables.
    let in_range = make_between(1, 10);
    assert(in_range(5));
    assert(in_range(1));
    assert(in_range(10));
    let out = in_range(11);
    assert(out == false);
    // Inline closure passed directly without binding.
    let results = [1, 2, 3];
    let sum_fn = fun(a: Int, b: Int) -> Int { a + b };
    assert(sum_fn(results[0], results[2]) == 4);
}
