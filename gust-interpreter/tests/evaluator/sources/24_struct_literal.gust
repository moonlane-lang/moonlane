struct Point { x: Int, y: Int }
struct Color { r: Int, g: Int, b: Int }

fun main() {
    // Basic struct construction.
    let p = Point { x: 3, y: 4 };
    assert(p.x == 3);
    assert(p.y == 4);
    // Multiple fields, different types.
    let c = Color { r: 255, g: 128, b: 0 };
    assert(c.r == 255);
    assert(c.g == 128);
    assert(c.b == 0);
}
