fun main() {
    // Plain assignment overwrites.
    mut x = 1;
    x = 99;
    assert(x == 99);
    // Compound integer operators.
    mut n = 20;
    n -= 5;
    assert(n == 15);
    n *= 2;
    assert(n == 30);
    n /= 3;
    assert(n == 10);
    n %= 3;
    assert(n == 1);
    // Compound float operators.
    mut f = 10.0;
    f += 5.0;
    assert(f == 15.0);
    f -= 3.0;
    assert(f == 12.0);
    f *= 2.0;
    assert(f == 24.0);
    f /= 4.0;
    assert(f == 6.0);
}
