// Positive: type parameters inside nested type positions (arrays, tuples, functions).

// T inside an array (using T[] postfix syntax).
fun array_first<T>(arr: T[]) -> T { arr[0] }

// T inside a tuple param.
fun fst<A, B>(pair: (A, B)) -> A { pair.0 }
fun snd<A, B>(pair: (A, B)) -> B { pair.1 }

// T as both array element and return.
fun wrap_in_pair<T>(arr: T[]) -> (T, T) { (arr[0], arr[1]) }

fun use_nested() -> Bool {
    let arr = [10, 20, 30];
    let n: Int = array_first(arr);

    let p = (true, 42);
    let b: Bool = fst(p);
    let _i: Int = snd(p);

    let nums = [1, 2];
    let pair: (Int, Int) = wrap_in_pair(nums);
    let _n2: Int = pair.1;

    b && (n == 10)
}
