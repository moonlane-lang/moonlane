// Positive: generic functions returning tuples built from type parameters.

fun make_pair<A, B>(a: A, b: B) -> (A, B) { (a, b) }
fun swap<A, B>(a: A, b: B) -> (B, A) { (b, a) }
fun dup<T>(x: T) -> (T, T) { (x, x) }

fun use_tuples() -> Int {
    let p: (Int, Bool) = make_pair(42, true);
    let s: (Bool, Int) = swap(1, false);
    let d: (Int, Int)  = dup(7);

    let _b1: Bool = p.1;
    let _b2: Bool = s.0;
    let _n2: Int  = d.1;

    p.0 + d.0
}
