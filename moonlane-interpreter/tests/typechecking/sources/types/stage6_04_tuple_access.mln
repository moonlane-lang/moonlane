// Stage 6: tuple access.

let pair: (Int, String) = (42, "hello");
let n: Int    = pair.0;
let s: String = pair.1;

// Nested tuples
let triple: (Int, Float, Bool) = (1, 2.0, true);
let a: Int   = triple.0;
let b: Float = triple.1;
let c: Bool  = triple.2;

// Tuple returned from a function
fun make_pair() -> (Int, String) {
    (10, "world")
}

let p = make_pair();
let x: Int    = p.0;
let y: String = p.1;
