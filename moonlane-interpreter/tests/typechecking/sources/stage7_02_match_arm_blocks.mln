// Stage 7: match arms with block bodies (RFC-0018).
// Arms can use either `=> expr` or `=> { stmts* expr? }`.

enum Shape {
    Circle { radius: Float },
    Rectangle { width: Float, height: Float },
}

let s: Shape = Shape::Circle { radius: 3.0 };

// Block arm with a local binding and computation.
let area: Float = match s {
    Shape::Circle { radius } => {
        let r = radius;
        r * r
    },
    Shape::Rectangle { width, height } => width * height,
};

// Block arm producing unit (no tail expression).
let msg: Perhaps<Int> = Perhaps::Some { value: 1 };
match msg {
    Perhaps::Some { value } => {
        let v = value;
    },
    nope => {},
};

// Mixed: one arm is a bare expr, one is a block.
let ok: Result<Int, String> = Result::Ok { value: 5 };
let n: Int = match ok {
    Result::Ok { value } => value,
    Result::Err { error } => {
        let fallback = 0;
        fallback
    },
};
