// Test: mutable binding type inference
//
// `mut` bindings behave identically to `let` for the purposes of type
// inference — the type is inferred from the initialiser, and an optional
// annotation is unified with it.
//
// Expected inferred types:
//   counter : Int    (inferred from literal 0)
//   flag    : Bool   (inferred from literal false)
//   name    : String (annotated String, value infers String — unification succeeds)

mut counter = 0;
mut flag    = false;
mut name: String = "moonlane";
