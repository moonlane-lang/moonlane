// Stage 7: return type propagation from function context.
// Pass 2 must propagate the declared return type into return/break expressions
// so that None and bare enum variants can be typed without a local annotation.

// Return None in a Perhaps<Int>-returning function.
fun find(arr: Int[], target: Int) -> Perhaps<Int> {
    return None;
}

// Return Result::Err where T is not present in Err's fields.
fun divide(a: Float, b: Float) -> Result<Float, String> {
    if (b == 0.0) {
        return Result::Err { error: "division by zero" };
    }
    return Result::Ok { value: a / b };
}

// Break None in a loop whose result is annotated as Perhaps<Int>.
fun first_positive(arr: Int[]) -> Perhaps<Int> {
    let result: Perhaps<Int> = loop {
        break None;
    };
    result
}
