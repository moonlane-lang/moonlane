// Stage 6: type casts (v0.1: identity casts and Int as Float widening only).

// Identity casts
let i: Int   = 42;
let i2: Int  = i as Int;

let g: Float = 3.14;
let f2: Float = g as Float;

// Widening cast: Int as Float
let as_float: Float = 7 as Float;

// Cast in arithmetic context
let area: Float = g as Float * 5.0 * 5.0;
