// Stage 6: enum declaration, construction, and pattern matching.

// User-defined enum with unit variants
enum Direction {
    North,
    South,
    East,
    West,
}

let d: Direction = Direction::North;

// User-defined enum with field variants
enum Shape {
    Circle { radius: Float },
    Rectangle { width: Float, height: Float },
}

let s1: Shape = Shape::Circle { radius: 5.0 };
let s2: Shape = Shape::Rectangle { width: 3.0, height: 4.0 };

// Match on user enum
let area: Float = match s1 {
    Shape::Circle { radius } => radius * radius,
    Shape::Rectangle { width, height } => width * height,
};

// Built-in Perhaps<T>
let some_val: Perhaps<Int> = Perhaps::Some { value: 42 };
let no_val: Perhaps<Int> = Perhaps::Nope;

// Match on Perhaps
let result_int: Int = match some_val {
    Perhaps::Some { value } => value,
    nope => 0,
};

// Built-in Result<T, E>
let ok_val: Result<Int, String> = Result::Ok { value: 10 };
let err_val: Result<Int, String> = Result::Err { error: "oops" };

// Match on Result
let extracted: Int = match ok_val {
    Result::Ok { value } => value,
    Result::Err { error } => 0,
};
