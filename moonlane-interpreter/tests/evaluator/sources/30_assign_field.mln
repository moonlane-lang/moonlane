struct Counter { value: Int, step: Int }

fun main() {
    // Plain field assignment.
    mut c = Counter { value: 0, step: 1 };
    c.value = 42;
    assert(c.value == 42);
    // Compound field assignment operators.
    c.value += 8;
    assert(c.value == 50);
    c.value -= 10;
    assert(c.value == 40);
    c.value *= 2;
    assert(c.value == 80);
    c.value /= 4;
    assert(c.value == 20);
    c.step += 9;
    assert(c.step == 10);
}
