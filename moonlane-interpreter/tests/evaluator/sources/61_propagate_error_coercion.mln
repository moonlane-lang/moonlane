// `?` operator with From coercion: E1 != E2, so `?` calls E2::from(E1).

aspect From<T> {
    fun from(value: T) -> Self;
}

struct ParseError {
    msg: String,
}

struct AppError {
    msg: String,
}

impl From<ParseError> for AppError {
    fun from(value: ParseError) -> AppError {
        return AppError { msg: string_concat("parse error: ", value.msg) };
    }
}

fun parse_int(s: String) -> Result<Int, ParseError> {
    if (s == "42") {
        return Result::Ok { value: 42 };
    }
    return Result::Err { error: ParseError { msg: "invalid integer" } };
}

fun load(s: String) -> Result<Int, AppError> {
    let n = parse_int(s)?;
    return Result::Ok { value: n * 2 };
}

fun main() {
    match load("42") {
        Result::Ok { value } => assert(value == 84),
        Result::Err { error } => assert(false),
    };

    match load("bad") {
        Result::Ok { value } => assert(false),
        Result::Err { error } => assert(error.msg == "parse error: invalid integer"),
    };
}
