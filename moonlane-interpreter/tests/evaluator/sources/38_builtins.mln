fun main() {
    // to_string method
    assert(0.to_string()     == "0");
    assert(42.to_string()    == "42");
    assert((-7).to_string()  == "-7");
    assert(1.5.to_string()   == "1.5");
    assert(0.0.to_string()   == "0");
    assert(true.to_string()  == "true");
    assert(false.to_string() == "false");
    // string_len
    assert(string_len("")        == 0);
    assert(string_len("hello")   == 5);
    assert(string_len("abc")     == 3);
    // string_concat
    assert(string_concat("foo", "bar") == "foobar");
    assert(string_concat("", "xyz")    == "xyz");
    assert(string_concat("abc", "")    == "abc");
    // array_len and array_push
    mut arr = [10, 20, 30];
    assert(array_len(arr) == 3);
    array_push(arr, 40);
    assert(array_len(arr) == 4);
    assert(arr[3] == 40);
    // array_push is in-place — subsequent reads see the added elements.
    array_push(arr, 50);
    array_push(arr, 60);
    assert(array_len(arr) == 6);
    assert(arr[5] == 60);
    // Building an array from scratch with push.
    mut built: Int[] = [];
    mut i = 1;
    while (i <= 5) {
        array_push(built, i * i);
        i += 1;
    }
    assert(array_len(built) == 5);
    assert(built[0] == 1);
    assert(built[4] == 25);
}
