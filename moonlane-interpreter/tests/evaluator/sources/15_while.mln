fun main() {
    // Basic while loop.
    mut i = 0;
    while (i < 5) { i = i + 1; }
    assert(i == 5);
    // Break exits the loop.
    mut j = 0;
    while (true) {
        if (j == 3) { break; }
        j = j + 1;
    }
    assert(j == 3);
    // False initial condition: body never executes.
    mut ran = 0;
    while (false) { ran = 1; }
    assert(ran == 0);
}
