fun main() {
    // Widening: Int as Float.
    let fi = 3 as Float;
    assert(fi == 3.0);
    // Identity casts.
    let ii = 5 as Int;
    assert(ii == 5);
    let ff = 2.5 as Float;
    assert(ff == 2.5);
    // Large integer to float.
    let big = 1000000 as Float;
    assert(big == 1000000.0);
    // Negative integer to float.
    let neg = -7 as Float;
    assert(neg == -7.0);
}
