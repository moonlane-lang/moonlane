// Generic functions.

// Identity function — returns its argument unchanged, works for any type.
fun id<T>(x: T) -> T { x }

// Swap — two type parameters.
fun swap<A, B>(a: A, b: B) -> (B, A) { (b, a) }

// First element of a pair via tuple access.
fun fst<A, B>(pair: (A, B)) -> A { pair.0 }

fun main() {
    // Identity at different types.
    assert(id(42) == 42);
    assert(id(true));
    assert(id("hello") == "hello");

    // Swap.
    let pair = swap(1, true);
    assert(pair.0 == true);
    assert(pair.1 == 1);

    // Fst.
    let p2 = (10, "world");
    assert(fst(p2) == 10);

    // Generic recursive call.
    assert(id(id(99)) == 99);

    // Swap with floats.
    let sp = swap(3.14, 0);
    assert(sp.0 == 0);
    assert(sp.1 == 3.14);

    // Generic function used in expression position.
    let x = id(100) + id(200);
    assert(x == 300);
}
