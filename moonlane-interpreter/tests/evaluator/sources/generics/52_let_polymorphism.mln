// Let-bound closures without annotations are generalized into polymorphic schemes.

let id = fun(x) { x };
let swap_vals = fun(a) { fun(b) { (b, a) } };

fun main() {
    // id used at Int, Bool, String.
    assert(id(42) == 42);
    assert(id(true));
    assert(id("hello") == "hello");

    // id in arithmetic context.
    assert(id(10) + id(20) == 30);

    // Nested id calls.
    assert(id(id(99)) == 99);

    // Two independent let-poly closures.
    let double = fun(n: Int) -> Int { n * 2 };
    let negate = fun(b: Bool) -> Bool { !b };
    assert(double(5) == 10);
    assert(negate(false));
}
