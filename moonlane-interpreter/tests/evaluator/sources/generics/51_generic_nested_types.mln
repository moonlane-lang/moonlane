// Generic functions operating on arrays and tuples as type parameter positions.

// First element of an array (using T[] postfix syntax).
fun array_first<T>(arr: T[]) -> T { arr[0] }

// Second element of an array.
fun array_second<T>(arr: T[]) -> T { arr[1] }

// First and second of a tuple.
fun fst<A, B>(pair: (A, B)) -> A { pair.0 }
fun snd<A, B>(pair: (A, B)) -> B { pair.1 }

// Swap elements of a tuple.
fun swap<A, B>(pair: (A, B)) -> (B, A) { (pair.1, pair.0) }

fun main() {
    // array_first / array_second at Int.
    let ints = [10, 20, 30];
    assert(array_first(ints) == 10);
    assert(array_second(ints) == 20);

    // array_first at Bool.
    let bools = [false, true];
    assert(!array_first(bools));
    assert(array_second(bools));

    // fst / snd on (Int, Bool).
    let p1 = (42, true);
    assert(fst(p1) == 42);
    assert(snd(p1));

    // fst / snd on (Bool, Int).
    let p2 = (false, 99);
    assert(!fst(p2));
    assert(snd(p2) == 99);

    // swap (Int, Bool) → (Bool, Int).
    let s1 = swap((7, true));
    assert(s1.0);
    assert(s1.1 == 7);

    // swap (String, Int).
    let s2 = swap(("hi", 5));
    assert(s2.0 == 5);
    assert(s2.1 == "hi");
}
