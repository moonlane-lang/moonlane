struct Box<T> {
    value: T,
}

struct Pair<A, B> {
    first: A,
    second: B,
}

fun main() {
    // Nested: Box<Pair<Int, Bool>>
    let bp = Box { value: Pair { first: 7, second: true } };
    assert(bp.value.first == 7);
    assert(bp.value.second);

    // Nested: Pair<Box<Int>, Box<Bool>>
    let pb = Pair { first: Box { value: 100 }, second: Box { value: false } };
    assert(pb.first.value == 100);
    assert(!pb.second.value);
}
