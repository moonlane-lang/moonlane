// Integration Test 2 — Battle Simulation
//
// Feature coverage:
//   enums (unit + field variants), structs/impl, tuples as return values,
//   match-with-blocks (RFC-0018), return nope / return Err (RFC-0019),
//   Perhaps<T>, closures as strategy values, while loop, for-in (range + array),
//   C-style for, higher-order functions, string operations, arrays of structs,
//   closure capture, named-function as closure argument.

// ── Action enum ───────────────────────────────────────────────────────────────

enum Action {
    Attack,
    Defend,
    Heal { amount: Int },
}

// ── Fighter struct ────────────────────────────────────────────────────────────

struct Fighter {
    name:    String,
    hp:      Int,
    max_hp:  Int,
    attack:  Int,
    defense: Int,
}

// ── Fighter methods ───────────────────────────────────────────────────────────

impl Fighter {
    fun is_alive(self) -> Bool {
        self.hp > 0
    }

    // Deals `raw` damage reduced by self.defense, minimum 1.
    fun take_damage(self, raw: Int) -> Fighter {
        let reduced = raw - self.defense;
        let dmg     = if (reduced > 1) { reduced } else { 1 };
        let new_hp  = if (self.hp - dmg > 0) { self.hp - dmg } else { 0 };
        Fighter {
            name:    self.name,
            hp:      new_hp,
            max_hp:  self.max_hp,
            attack:  self.attack,
            defense: self.defense,
        }
    }

    // Heals by `amount`, capped at max_hp.
    fun heal(self, amount: Int) -> Fighter {
        let new_hp = if (self.hp + amount < self.max_hp) {
            self.hp + amount
        } else {
            self.max_hp
        };
        Fighter {
            name:    self.name,
            hp:      new_hp,
            max_hp:  self.max_hp,
            attack:  self.attack,
            defense: self.defense,
        }
    }

    // Raises defense by `bonus`.
    fun add_defense(self, bonus: Int) -> Fighter {
        Fighter {
            name:    self.name,
            hp:      self.hp,
            max_hp:  self.max_hp,
            attack:  self.attack,
            defense: self.defense + bonus,
        }
    }

    // Short string representation: "Name[hp/max_hp]".
    fun summary(self) -> String {
        let part1 = string_concat(self.name, "[");
        let part2 = string_concat(self.hp.to_string(), "/");
        let part3 = string_concat(self.max_hp.to_string(), "]");
        string_concat(part1, string_concat(part2, part3))
    }
}

// ── Combat resolution ─────────────────────────────────────────────────────────

// Apply one action.  Returns (updated_actor, updated_target).
// Uses match-with-blocks (RFC-0018) for the Heal arm.
fun resolve(action: Action, actor: Fighter, target: Fighter) -> (Fighter, Fighter) {
    match action {
        Action::Attack => {
            let damaged = target.take_damage(actor.attack);
            (actor, damaged)
        },
        Action::Defend => {
            let buffed = actor.add_defense(3);
            (buffed, target)
        },
        Action::Heal { amount } => {
            let healed = actor.heal(amount);
            (healed, target)
        },
    }
}

// ── Describe action (also exercises match-with-blocks) ────────────────────────

fun describe_action(action: Action) -> String {
    match action {
        Action::Attack          => "attacks",
        Action::Defend          => "defends",
        Action::Heal { amount } => {
            string_concat("heals for ", amount.to_string())
        },
    }
}

// ── Strategy functions ────────────────────────────────────────────────────────

// Always attacks.
fun always_attack(actor: Fighter, target: Fighter) -> Action {
    Action::Attack
}

// Heals when below half HP, otherwise attacks.
fun smart_healer(actor: Fighter, target: Fighter) -> Action {
    if (actor.hp * 2 < actor.max_hp) {
        Action::Heal { amount: 20 }
    } else {
        Action::Attack
    }
}

// Defends to build defense while it is low, otherwise attacks.
fun defender_strategy(actor: Fighter, target: Fighter) -> Action {
    if (actor.defense < 8) {
        Action::Defend
    } else {
        Action::Attack
    }
}

// ── Utilities ─────────────────────────────────────────────────────────────────

// "R<n> | <f1 summary> vs <f2 summary>"
fun format_round(round: Int, f1: Fighter, f2: Fighter) -> String {
    let prefix = string_concat("R", round.to_string());
    let mid    = string_concat(f1.summary(), " vs ");
    string_concat(string_concat(prefix, " | "), string_concat(mid, f2.summary()))
}

// Sum of HP across all fighters in the party.
fun total_party_hp(party: Fighter[]) -> Int {
    mut total = 0;
    for (let f in party) { total += f.hp; }
    total
}

// Index of the fighter with highest attack.  Returns nope for an empty party.
fun best_attacker_idx(party: Fighter[]) -> Perhaps<Int> {
    let n = array_len(party);
    if (n == 0) { return nope; }
    mut best = 0;
    for (mut i = 1; i < n; i += 1) {
        if (party[i].attack > party[best].attack) {
            best = i;
        }
    }
    Perhaps::Some { value: best }
}

// Apply `action_fn` for `n` rounds (f1 always acts, f2 never).
// Returns the final (f1, f2) pair.
fun simulate_rounds(
    f1_init:   Fighter,
    f2_init:   Fighter,
    action_fn: fun(Fighter, Fighter) -> Action,
    n:         Int
) -> (Fighter, Fighter) {
    mut f1 = f1_init;
    mut f2 = f2_init;
    mut i  = 0;
    while (i < n) {
        let a  = action_fn(f1, f2);
        let r  = resolve(a, f1, f2);
        f1 = r.0;
        f2 = r.1;
        i += 1;
    }
    (f1, f2)
}

// ── Battle simulation ─────────────────────────────────────────────────────────

// Simulate up to `max_rounds` alternating rounds.
// Returns Perhaps::Some with the winner's name, or nope for a draw.
// Uses RFC-0019: `return Perhaps::Some { value: ... }` and `return nope`.
fun battle(
    f1_init:    Fighter,
    s1:         fun(Fighter, Fighter) -> Action,
    f2_init:    Fighter,
    s2:         fun(Fighter, Fighter) -> Action,
    max_rounds: Int
) -> Perhaps<String> {
    mut f1    = f1_init;
    mut f2    = f2_init;
    mut round = 0;
    while (round < max_rounds) {
        // Fighter 1 acts.
        let a1 = s1(f1, f2);
        let r1 = resolve(a1, f1, f2);
        f1 = r1.0;
        f2 = r1.1;
        if (!f2.is_alive()) {
            return Perhaps::Some { value: f1.name };
        }
        // Fighter 2 acts.
        let a2 = s2(f2, f1);
        let r2 = resolve(a2, f2, f1);
        f2 = r2.0;
        f1 = r2.1;
        if (!f1.is_alive()) {
            return Perhaps::Some { value: f2.name };
        }
        round += 1;
    }
    nope
}

// ── Entry point ───────────────────────────────────────────────────────────────

fun main() {
    let knight = Fighter { name: "Knight", hp: 100, max_hp: 100, attack: 25, defense: 5 };
    let goblin  = Fighter { name: "Goblin",  hp: 30,  max_hp: 30,  attack: 8,  defense: 2 };
    let mage    = Fighter { name: "Mage",    hp: 60,  max_hp: 60,  attack: 30, defense: 1 };
    let healer  = Fighter { name: "Healer",  hp: 50,  max_hp: 50,  attack: 5,  defense: 3 };

    // 1. take_damage: net = raw - defense (minimum 1).
    // Knight takes 8 raw: 8-5=3 net → hp=97.
    let wounded = knight.take_damage(8);
    assert(wounded.hp == 97);
    // Goblin takes 3 raw: 3-2=1, exactly the minimum → hp=29.
    let scratched = goblin.take_damage(3);
    assert(scratched.hp == 29);
    // take_damage that kills: hp floors at 0.
    let dead = goblin.take_damage(100);
    assert(dead.hp == 0);
    assert(!dead.is_alive());

    // 2. heal: capped at max_hp.
    let injured = Fighter { name: "Test", hp: 40, max_hp: 50, attack: 10, defense: 5 };
    let full    = injured.heal(20);  // 40+20=60 > 50 → 50
    let partial = injured.heal(5);   // 40+5=45 < 50 → 45
    assert(full.hp    == 50);
    assert(partial.hp == 45);

    // 3. add_defense: only defense field changes.
    let buffed = knight.add_defense(3);
    assert(buffed.defense == 8);
    assert(buffed.hp      == 100);

    // 4. is_alive.
    assert(knight.is_alive());
    assert(!dead.is_alive());

    // 5. resolve Attack: actor unchanged, target takes damage.
    // Knight attacks Goblin: 25-2=23 damage, 30-23=7 hp.
    let r_atk = resolve(Action::Attack, knight, goblin);
    assert(r_atk.0.hp == 100);
    assert(r_atk.1.hp == 7);

    // 6. resolve Heal: actor healed, target unchanged.
    let half_hp = Fighter { name: "Half", hp: 25, max_hp: 50, attack: 10, defense: 5 };
    let r_heal  = resolve(Action::Heal { amount: 15 }, half_hp, goblin);
    assert(r_heal.0.hp == 40);
    assert(r_heal.1.hp == 30);

    // 7. resolve Defend: actor gains +3 defense, target unchanged.
    let r_def = resolve(Action::Defend, goblin, knight);
    assert(r_def.0.defense == 5);
    assert(r_def.1.hp      == 100);

    // 8. describe_action — match-with-blocks on enum with fields.
    let desc_atk  = describe_action(Action::Attack);
    let desc_def  = describe_action(Action::Defend);
    let desc_heal = describe_action(Action::Heal { amount: 15 });
    assert(string_len(desc_atk)  > 0);
    assert(string_len(desc_def)  > 0);
    assert(string_len(desc_heal) > 0);

    // 9. always_attack: must return Attack variant.
    let a_atk = always_attack(knight, goblin);
    match a_atk {
        Action::Attack          => (),
        Action::Defend          => assert_msg(false, "expected Attack"),
        Action::Heal { amount } => assert_msg(false, "expected Attack"),
    };

    // 10. smart_healer: heals when below half HP, attacks when ok.
    let low_hp     = Fighter { name: "Low", hp: 10, max_hp: 50, attack: 10, defense: 5 };
    let heal_choice = smart_healer(low_hp, goblin);  // 10*2=20 < 50 → Heal
    match heal_choice {
        Action::Heal { amount } => assert(amount == 20),
        Action::Attack          => assert_msg(false, "expected Heal"),
        Action::Defend          => assert_msg(false, "expected Heal"),
    };
    let ok_hp      = Fighter { name: "Ok", hp: 40, max_hp: 50, attack: 10, defense: 5 };
    let atk_choice  = smart_healer(ok_hp, goblin);  // 40*2=80 > 50 → Attack
    match atk_choice {
        Action::Attack          => (),
        Action::Defend          => assert_msg(false, "expected Attack"),
        Action::Heal { amount } => assert_msg(false, "expected Attack"),
    };

    // 11. defender_strategy: defends when defense < 8, attacks otherwise.
    let def_action  = defender_strategy(goblin, knight);   // goblin.def=2 < 8 → Defend
    let def_action2 = defender_strategy(knight, goblin);   // knight.def=5 < 8 → Defend
    let def_action3 = defender_strategy(buffed, goblin);   // buffed.def=8, not < 8 → Attack
    match def_action  { Action::Defend => (), Action::Attack => assert_msg(false, "expected Defend"), Action::Heal { amount } => assert_msg(false, "expected Defend"), };
    match def_action2 { Action::Defend => (), Action::Attack => assert_msg(false, "expected Defend"), Action::Heal { amount } => assert_msg(false, "expected Defend"), };
    match def_action3 { Action::Attack => (), Action::Defend => assert_msg(false, "expected Attack"), Action::Heal { amount } => assert_msg(false, "expected Attack"), };

    // 12. simulate_rounds: 1 round where Knight attacks Goblin.
    // After 1 round: Goblin hp = 30 - (25-2) = 7.  Knight unchanged.
    let sim1 = simulate_rounds(knight, goblin, always_attack, 1);
    assert(sim1.0.hp == 100);
    assert(sim1.1.hp == 7);

    // 13. format_round returns a non-empty string.
    let round_str = format_round(3, knight, goblin);
    assert(string_len(round_str) > 0);

    // 14. Battle: Knight (aggressive) vs Goblin (aggressive) — Knight wins.
    //   Round 1: Knight hits Goblin for 23 → hp=7; Goblin hits Knight for 3 → hp=97.
    //   Round 2: Knight hits Goblin for 23 → hp=0.  Knight wins.
    let result1 = battle(knight, always_attack, goblin, always_attack, 10);
    match result1 {
        Perhaps::Some { value } => assert(string_len(value) > 0),
        nope => assert_msg(false, "expected Some"),
    };

    // 15. Battle: draw when max_rounds = 0 (no rounds fought).
    let draw = battle(knight, always_attack, goblin, always_attack, 0);
    match draw { Perhaps::Some { value } => assert_msg(false, "expected nope"), nope => (), };

    // 16. Battle with inline closure strategy and named-function strategy.
    //   Mage (atk=30, def=1) always attacks; Healer uses smart_healer.
    //   Mage deals 30-3=27/round; Healer heals when < half HP.
    //   Healer falls behind eventually and Mage wins within 20 rounds.
    let result2 = battle(
        mage,
        fun(a: Fighter, t: Fighter) -> Action { Action::Attack },
        healer,
        smart_healer,
        20
    );
    match result2 {
        Perhaps::Some { value } => (),
        nope => assert_msg(false, "expected Some"),
    };

    // 17. Closure capturing an outer variable (hp threshold for heal decision).
    let hp_threshold = 25;
    let threshold_healer = fun(actor: Fighter, target: Fighter) -> Action {
        if (actor.hp < hp_threshold) {
            Action::Heal { amount: 10 }
        } else {
            Action::Attack
        }
    };
    // Knight hp=100 ≥ 25 → Attack.
    let tc1 = threshold_healer(knight, goblin);
    match tc1 { Action::Attack => (), Action::Defend => assert_msg(false, "expected Attack"), Action::Heal { amount } => assert_msg(false, "expected Attack"), };
    // low_hp hp=10 < 25 → Heal { amount: 10 }.
    let tc2 = threshold_healer(low_hp, goblin);
    match tc2 {
        Action::Heal { amount } => assert(amount == 10),
        Action::Attack          => assert_msg(false, "expected Heal"),
        Action::Defend          => assert_msg(false, "expected Heal"),
    };

    // 18. Array of fighters: total HP and best attacker index.
    let party: Fighter[] = [
        Fighter { name: "A", hp: 80,  max_hp: 80,  attack: 15, defense: 8 },
        Fighter { name: "B", hp: 60,  max_hp: 60,  attack: 20, defense: 3 },
        Fighter { name: "C", hp: 100, max_hp: 100, attack: 10, defense: 12 },
    ];
    let total_hp = total_party_hp(party);
    assert(total_hp == 240);

    let best_idx = best_attacker_idx(party);
    match best_idx {
        Perhaps::Some { value } => assert(value == 1),
        nope => assert_msg(false, "expected Some"),
    };
    // Empty party returns nope.
    let empty_party: Fighter[] = [];
    let no_best = best_attacker_idx(empty_party);
    match no_best { Perhaps::Some { value } => assert_msg(false, "expected nope"), nope => (), };

    // 19. Count alive fighters in party via for-in (all have hp > 0).
    mut alive_count = 0;
    for (let f in party) {
        if (f.is_alive()) { alive_count += 1; }
    }
    assert(alive_count == 3);

    // 20. Range for-in: accumulate damage Knight deals over 5 rounds (25-2=23/round).
    mut total_damage = 0;
    for (let r in 0..5) {
        total_damage += knight.attack - goblin.defense;
    }
    assert(total_damage == 115);

    // 21. C-style for: apply Defend action `n` times and check final defense.
    // Goblin starts at defense=2; each Defend adds 3.  After 4 rounds: 2+4*3=14.
    mut cur_goblin = goblin;
    for (mut k = 0; k < 4; k += 1) {
        let rd = resolve(Action::Defend, cur_goblin, knight);
        cur_goblin = rd.0;
    }
    assert(cur_goblin.defense == 14);

    // 22. Tuple: pair the round count with the final fighter state.
    let rounds_fought = 4;
    let report: (Int, Fighter) = (rounds_fought, cur_goblin);
    assert(report.0 == 4);
    assert(report.1.defense == 14);
}
