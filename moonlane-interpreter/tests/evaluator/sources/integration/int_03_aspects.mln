// Integration Test 3 — Shape Geometry Library
//
// Feature coverage (v0.4):
//   user aspect declaration (Measurable, Describable),
//   impl Aspect for Type and method dispatch on multiple types,
//   both aspects implemented on the same type (Circle, Rectangle),
//   to_string on Int / Float / Bool / String (all four built-in Display types),
//   polymorphic print / println,
//   user-defined Iterable<Float> (AreaList) — stateful forward scan,
//   empty Iterable guard (loop body skipped),
//   From<Celsius> for Fahrenheit / From<Fahrenheit> for Celsius,
//   Celsius→Fahrenheit→Celsius round-trip (numeric stability),
//   built-in From: Int as Float, Float as Int (truncation),
//   ? operator with From coercion: ParseError → ShapeError.

// ── Aspects ────────────────────────────────────────────────────────────────────

aspect Measurable {
    fun area(self) -> Float;
    fun perimeter(self) -> Float;
}

aspect Describable {
    fun describe(self) -> String;
}

aspect Iterable<T> {
    fun next(mut self) -> Perhaps<T>;
}

aspect From<T> {
    fun from(value: T) -> Self;
}

// ── Utilities ──────────────────────────────────────────────────────────────────

fun pi() -> Float { 3.14159 }

fun approx(a: Float, b: Float) -> Bool {
    let d = a - b;
    let abs_d = if (d < 0.0) { 0.0 - d } else { d };
    abs_d < 0.01
}

// ── Shape types ────────────────────────────────────────────────────────────────

struct Circle    { radius: Int }
struct Rectangle { width: Int, height: Int }

impl Measurable for Circle {
    fun area(self) -> Float {
        let r = self.radius as Float;
        pi() * r * r
    }
    fun perimeter(self) -> Float {
        2.0 * pi() * (self.radius as Float)
    }
}

impl Describable for Circle {
    fun describe(self) -> String {
        string_concat("Circle(r=", string_concat(self.radius.to_string(), ")"))
    }
}

impl Measurable for Rectangle {
    fun area(self) -> Float {
        (self.width * self.height) as Float
    }
    fun perimeter(self) -> Float {
        (2 * (self.width + self.height)) as Float
    }
}

impl Describable for Rectangle {
    fun describe(self) -> String {
        string_concat("Rect(", string_concat(self.width.to_string(),
            string_concat("x", string_concat(self.height.to_string(), ")"))))
    }
}

// ── User-defined Iterable ──────────────────────────────────────────────────────

struct AreaList { data: Float[], pos: Int }

impl AreaList {
    fun new(data: Float[]) -> AreaList { AreaList { data: data, pos: 0 } }
    fun len(self) -> Int { array_len(self.data) }
}

impl Iterable<Float> for AreaList {
    fun next(mut self) -> Perhaps<Float> {
        if (self.pos < array_len(self.data)) {
            let v = self.data[self.pos];
            self.pos = self.pos + 1;
            Perhaps::Some { value: v }
        } else {
            None
        }
    }
}

// ── Temperature — user-defined From ───────────────────────────────────────────

struct Celsius    { degrees: Float }
struct Fahrenheit { degrees: Float }

impl From<Celsius> for Fahrenheit {
    fun from(value: Celsius) -> Fahrenheit {
        Fahrenheit { degrees: value.degrees * 1.8 + 32.0 }
    }
}

impl From<Fahrenheit> for Celsius {
    fun from(value: Fahrenheit) -> Celsius {
        Celsius { degrees: (value.degrees - 32.0) / 1.8 }
    }
}

// ── Error types + ? coercion ───────────────────────────────────────────────────

struct ParseError { msg: String }
struct ShapeError { msg: String }

impl From<ParseError> for ShapeError {
    fun from(value: ParseError) -> ShapeError {
        ShapeError { msg: string_concat("parse error: ", value.msg) }
    }
}

fun parse_radius(s: String) -> Result<Int, ParseError> {
    if (s == "5") {
        Result::Ok { value: 5 }
    } else if (s == "10") {
        Result::Ok { value: 10 }
    } else {
        Result::Err { error: ParseError { msg: string_concat("bad radius: ", s) } }
    }
}

// ? converts ParseError → ShapeError via From.
fun circle_area_from_str(s: String) -> Result<Float, ShapeError> {
    let r = parse_radius(s)?;
    let c = Circle { radius: r };
    Result::Ok { value: c.area() }
}

// ── main ───────────────────────────────────────────────────────────────────────

fun main() {
    let c5  = Circle { radius: 5 };
    let r34 = Rectangle { width: 3, height: 4 };
    let c10 = Circle { radius: 10 };

    // Measurable on Circle: area ≈ 78.54, perimeter ≈ 31.42
    assert(approx(c5.area(), 78.54));
    assert(approx(c5.perimeter(), 31.42));

    // Measurable on Rectangle: exact integers
    assert(r34.area() == 12.0);
    assert(r34.perimeter() == 14.0);

    // Larger circle: area ≈ 314.16
    assert(approx(c10.area(), 314.16));

    // Describable: both aspects coexist on the same type
    assert(c5.describe() == "Circle(r=5)");
    assert(r34.describe() == "Rect(3x4)");
    assert(c10.describe() == "Circle(r=10)");

    // Aspect methods and regular methods coexist
    assert(c5.describe() == "Circle(r=5)");
    assert(c5.area() > 0.0);

    // to_string on Int: positive, zero, multi-digit
    let n42: Int = 42;
    let nz: Int = 0;
    let big: Int = 1000;
    assert(n42.to_string() == "42");
    assert(nz.to_string() == "0");
    assert(big.to_string() == "1000");

    // to_string on Float: whole number → no decimal, fractional → keeps decimal
    let f5: Float = 5.0;
    let frac: Float = 3.14;
    assert(f5.to_string() == "5");
    assert(frac.to_string() == "3.14");

    // to_string on Bool
    assert(true.to_string() == "true");
    assert(false.to_string() == "false");

    // to_string on String (identity)
    let greeting: String = "hello";
    assert(greeting.to_string() == "hello");

    // polymorphic print / println accept any Display type
    print(42);
    print(true);
    println(3.14);
    println("done");

    // User-defined Iterable: collect all areas into a total
    let areas: Float[] = [c5.area(), r34.area(), c10.area()];
    let seq = AreaList::new(areas);
    assert(seq.len() == 3);
    mut total_area = 0.0;
    for (let a in seq) { total_area += a; }
    // ≈ 78.54 + 12.0 + 314.16 = 404.70
    assert(approx(total_area, 404.70));

    // Empty Iterable: loop body never runs
    mut body_ran: Bool = false;
    let empty_areas: Float[] = [];
    for (let _a in AreaList::new(empty_areas)) { body_ran = true; }
    assert(!body_ran);

    // From<Celsius> for Fahrenheit: boiling point
    let boiling = Celsius { degrees: 100.0 };
    let boiling_f = boiling as Fahrenheit;
    assert(boiling_f.degrees == 212.0);

    // From<Fahrenheit> for Celsius: freezing point
    let freezing_f = Fahrenheit { degrees: 32.0 };
    let freezing_c = freezing_f as Celsius;
    assert(approx(freezing_c.degrees, 0.0));

    // Round-trip: Celsius → Fahrenheit → Celsius
    let body = Celsius { degrees: 37.0 };
    let body_f = body as Fahrenheit;
    assert(approx(body_f.degrees, 98.60));
    let body_back = body_f as Celsius;
    assert(approx(body_back.degrees, 37.0));

    // Built-in From: Int as Float (exact)
    let seven: Int = 7;
    let seven_f = seven as Float;
    assert(seven_f == 7.0);

    // Built-in From: Float as Int (truncation toward zero)
    let pi_approx: Float = 3.9;
    let pi_int = pi_approx as Int;
    assert(pi_int == 3);

    // ? success path: parse "5", build Circle, return area
    let area_ok = circle_area_from_str("5");
    match area_ok {
        Result::Ok  { value } => assert(approx(value, 78.54)),
        Result::Err { error } => assert(false),
    };

    // ? success path: parse "10"
    let area_ok2 = circle_area_from_str("10");
    match area_ok2 {
        Result::Ok  { value } => assert(approx(value, 314.16)),
        Result::Err { error } => assert(false),
    };

    // ? failure path: ParseError wrapped into ShapeError via From
    let area_err = circle_area_from_str("bad");
    match area_err {
        Result::Ok  { value } => assert(false),
        Result::Err { error } => assert(error.msg == "parse error: bad radius: bad"),
    };
}
