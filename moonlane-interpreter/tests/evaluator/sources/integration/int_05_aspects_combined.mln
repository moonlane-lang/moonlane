// Integration Test 5 — Combined Aspects: Task Runner
//
// Feature coverage (v0.4):
//   multiple aspects on the same struct (Runnable, Describable),
//   Countdown — user Iterable<Int> counting down,
//   break / continue inside a for-in loop over user Iterable,
//   ? with same-type error (no From needed),
//   ? with From coercion (ConfigError → RunError),
//   ? inside a for-in loop (early exit on first Err),
//   nested for-in loops,
//   to_string on Int / Bool.

// ── Aspects ────────────────────────────────────────────────────────────────────

aspect Runnable {
    fun run(self) -> String;
}

aspect Describable {
    fun describe(self) -> String;
}

aspect From<T> {
    fun from(value: T) -> Self;
}

aspect Iterable<T> {
    fun next(mut self) -> Perhaps<T>;
}

// ── Error types ────────────────────────────────────────────────────────────────

struct ConfigError { msg: String }
struct RunError    { msg: String }

impl From<ConfigError> for RunError {
    fun from(value: ConfigError) -> RunError {
        RunError { msg: string_concat("config: ", value.msg) }
    }
}

// ── Task types ─────────────────────────────────────────────────────────────────

struct Task { name: String, enabled: Bool }

impl Runnable for Task {
    fun run(self) -> String {
        if (self.enabled) {
            string_concat(self.name, ":ok")
        } else {
            string_concat(self.name, ":skip")
        }
    }
}

impl Describable for Task {
    fun describe(self) -> String {
        string_concat("Task[", string_concat(self.name, string_concat(", enabled=",
            string_concat(self.enabled.to_string(), "]"))))
    }
}

// ── Countdown Iterable ─────────────────────────────────────────────────────────

struct Countdown { current: Int }

impl Countdown {
    fun new(start: Int) -> Countdown { Countdown { current: start } }
}

impl Iterable<Int> for Countdown {
    fun next(mut self) -> Perhaps<Int> {
        if (self.current > 0) {
            let v = self.current;
            self.current = self.current - 1;
            Perhaps::Some { value: v }
        } else {
            None
        }
    }
}

// ── Fallible config loader ─────────────────────────────────────────────────────

fun load_config(key: String) -> Result<String, ConfigError> {
    if (key == "timeout") { Result::Ok { value: "30" } }
    else if (key == "mode") { Result::Ok { value: "fast" } }
    else { Result::Err { error: ConfigError { msg: string_concat("unknown key: ", key) } } }
}

// same-type ? (ConfigError → ConfigError, no From needed)
fun require_config(key: String) -> Result<String, ConfigError> {
    let v = load_config(key)?;
    Result::Ok { value: v }
}

// ? with From: ConfigError → RunError
fun run_with_config(key: String) -> Result<String, RunError> {
    let v = load_config(key)?;
    Result::Ok { value: string_concat("ran:", v) }
}

// ── main ───────────────────────────────────────────────────────────────────────

fun main() {
    // Both aspects on the same struct
    let t1 = Task { name: "build", enabled: true };
    let t2 = Task { name: "test",  enabled: false };

    assert(t1.run()      == "build:ok");
    assert(t2.run()      == "test:skip");
    assert(t1.describe() == "Task[build, enabled=true]");
    assert(t2.describe() == "Task[test, enabled=false]");

    // Countdown Iterable: 3,2,1
    mut count_sum = 0;
    for (let v in Countdown::new(3)) { count_sum += v; }
    assert(count_sum == 6); // 3+2+1

    // Empty countdown
    mut ran = false;
    for (let _v in Countdown::new(0)) { ran = true; }
    assert(!ran);

    // break inside for-in: stop after first even number
    mut first_even = -1;
    for (let v in Countdown::new(10)) {
        let rem = v - (v / 2 * 2);
        if (rem == 0) {
            first_even = v;
            break;
        }
    }
    assert(first_even == 10); // 10 is even, it's the first emitted (countdown from 10)

    // continue inside for-in: sum only odd numbers in [1..5]
    mut odd_sum = 0;
    for (let v in Countdown::new(5)) {
        let rem = v - (v / 2 * 2);
        if (rem == 0) { continue; }
        odd_sum += v;
    }
    assert(odd_sum == 9); // 5+3+1

    // nested for-in: 3x3 multiplication table sum = (1+2+3)*(1+2+3) = 36
    mut mult_sum = 0;
    for (let i in Countdown::new(3)) {
        for (let j in Countdown::new(3)) {
            mult_sum += i * j;
        }
    }
    assert(mult_sum == 36);

    // same-type ?: success
    let r1 = require_config("timeout");
    match r1 {
        Result::Ok  { value } => assert(value == "30"),
        Result::Err { error } => assert(false),
    };

    // same-type ?: failure (ConfigError pass-through)
    let r2 = require_config("bad");
    match r2 {
        Result::Ok  { value } => assert(false),
        Result::Err { error } => assert(error.msg == "unknown key: bad"),
    };

    // ? with From: success
    let r3 = run_with_config("mode");
    match r3 {
        Result::Ok  { value } => assert(value == "ran:fast"),
        Result::Err { error } => assert(false),
    };

    // ? with From: ConfigError coerced to RunError
    let r4 = run_with_config("missing");
    match r4 {
        Result::Ok  { value } => assert(false),
        Result::Err { error } => assert(error.msg == "config: unknown key: missing"),
    };

    // to_string on Bool
    assert(true.to_string()  == "true");
    assert(false.to_string() == "false");

    // to_string on Int
    assert(100.to_string() == "100");
    assert(0.to_string()   == "0");

    // Direct From cast
    let ce = ConfigError { msg: "fail" };
    let re = ce as RunError;
    assert(re.msg == "config: fail");
}
