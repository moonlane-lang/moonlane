fun make_adder(x: Int) -> fun(Int) -> Int {
    fun(y: Int) -> Int { x + y }
}
fun apply(f: fun(Int) -> Int, v: Int) -> Int {
    f(v)
}
fun main() {
    let add5 = make_adder(5);
    let r1 = add5(3);
    assert(r1 == 8);
    let r2 = add5(10);
    assert(r2 == 15);
    // Pass a closure to a higher-order function.
    let add10 = make_adder(10);
    let r3 = apply(add10, 7);
    assert(r3 == 17);
    // Closure created inline.
    let double = fun(n: Int) -> Int { n * 2 };
    let r4 = double(6);
    assert(r4 == 12);
}
