// 02 — Control flow
// Covers: if/else (statement and expression), while, C-style for, for-in,
//         loop, break, break-with-value, continue, return.

fun sign(n: Int) -> String {
    if (n > 0) {
        return "positive";
    } else if (n < 0) {
        return "negative";
    } else {
        return "zero";
    }
}

fun sum_to(n: Int) -> Int {
    mut total = 0;
    mut i = 1;
    while (i <= n) {
        total += i;
        i += 1;
    }
    return total;
}

fun first_even_above(start: Int) -> Int {
    // loop + break with value
    let result = loop {
        if (start % 2 == 0) {
            break start;
        }
        start += 1;
    };
    return result;
}

fun main() {
    // --- if as statement ---
    println(sign(5));    // positive
    println(sign(-3));   // negative
    println(sign(0));    // zero

    // --- if as expression ---
    let label = if (10 > 5) { "yes" } else { "no" };
    println(label);      // yes

    // --- while ---
    println(int_to_string(sum_to(10)));   // 55

    // --- C-style for ---
    mut c_sum = 0;
    for (mut i = 1; i <= 5; i += 1) {
        c_sum += i;
    }
    println(int_to_string(c_sum));        // 15

    // --- for-in over array ---
    let nums: Int[] = [10, 20, 30];
    mut for_in_sum = 0;
    for (let n in nums) {
        for_in_sum += n;
    }
    println(int_to_string(for_in_sum));   // 60

    // --- loop + break with value ---
    println(int_to_string(first_even_above(7)));  // 8

    // --- continue: sum only even numbers 1..10 ---
    mut even_sum = 0;
    for (mut i = 1; i <= 10; i += 1) {
        if (i % 2 != 0) {
            continue;
        }
        even_sum += i;
    }
    println(int_to_string(even_sum));     // 30

    // --- break exits loop early ---
    mut found = -1;
    mut i = 0;
    while (i < 100) {
        if (i * i > 50) {
            found = i;
            break;
        }
        i += 1;
    }
    println(int_to_string(found));        // 8  (8*8=64 > 50)
}
