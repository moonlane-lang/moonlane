// 03 — Functions and closures
// Covers: named functions, first-class functions, closures, closure captures,
//         mut capture, generic functions, higher-order functions, closure type signatures,
//         unannotated parameters (types inferred from context).

fun add(a: Int, b: Int) -> Int {
    return a + b;
}

fun apply(f: fun(Int) -> Int, x: Int) -> Int {
    return f(x);
}

fun apply2(f: fun(Int, Int) -> Int, a: Int, b: Int) -> Int {
    return f(a, b);
}

fun make_adder(n: Int) -> fun(Int) -> Int {
    return fun(x) { return x + n; };   // x inferred as Int from return type
}

fun identity<T>(value: T) -> T {
    return value;
}

fun map_array(arr: Int[], f: fun(Int) -> Int) -> Int[] {
    mut result: Int[] = [];
    for (let item in arr) {
        array_push(result, f(item));
    }
    return result;
}

fun main() {
    // --- basic call ---
    println(int_to_string(add(3, 4)));    // 7

    // --- function assigned to variable ---
    let f = add;
    println(int_to_string(f(10, 20)));    // 30

    // --- closure passed to function (params inferred from apply's signature) ---
    let doubled = apply(fun(x) { return x * 2; }, 5);
    println(int_to_string(doubled));      // 10

    // --- closure capturing an outer variable ---
    let factor = 3;
    let tripled = apply(fun(x) { return x * factor; }, 7);
    println(int_to_string(tripled));      // 21

    // --- closure mutating a captured mut variable ---
    mut count = 0;
    let increment = fun() { count += 1; };
    increment();
    increment();
    increment();
    println(int_to_string(count));        // 3

    // --- higher-order: make_adder returns a closure ---
    let add5 = make_adder(5);
    println(int_to_string(add5(10)));     // 15
    println(int_to_string(add5(100)));    // 105

    // --- generic function ---
    println(int_to_string(identity(42)));       // 42
    println(identity("hello"));                 // hello

    // --- apply2 with named function ---
    println(int_to_string(apply2(add, 8, 9)));  // 17

    // --- map_array (closure params inferred from map_array's signature) ---
    let nums: Int[] = [1, 2, 3, 4, 5];
    let squares = map_array(nums, fun(x) { return x * x; });
    for (let n in squares) {
        print(int_to_string(n) + " ");    // 1 4 9 16 25
    }
    println("");
}
