fun main() {
    // Construction and element access.
    let t = (10, 20);
    let _ok1 = match (t.0 == 10) { true => 0, _ => 0 / 0, };
    let _ok2 = match (t.1 == 20) { true => 0, _ => 0 / 0, };
    // Mixed types.
    let pair = (1, true);
    let _ok3 = match (pair.0 == 1) { true => 0, _ => 0 / 0, };
    let _ok4 = match pair.1        { true => 0, _ => 0 / 0, };
    // Nested tuple.
    let nested = (1, (2, 3));
    let inner = nested.1;
    let _ok5 = match (inner.0 == 2) { true => 0, _ => 0 / 0, };
    let _ok6 = match (inner.1 == 3) { true => 0, _ => 0 / 0, };
}
