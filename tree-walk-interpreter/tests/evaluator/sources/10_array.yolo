fun main() {
    // Construction and indexing.
    let arr = [1, 2, 3];
    let _ok1 = match (arr[0] == 1) { true => 0, _ => 0 / 0, };
    let _ok2 = match (arr[1] == 2) { true => 0, _ => 0 / 0, };
    let _ok3 = match (arr[2] == 3) { true => 0, _ => 0 / 0, };
    // Last valid index.
    let last = [10, 20, 30];
    let _ok4 = match (last[2] == 30) { true => 0, _ => 0 / 0, };
}
