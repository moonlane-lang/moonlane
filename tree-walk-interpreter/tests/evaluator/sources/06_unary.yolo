fun main() {
    let _ok1 = match (-5   == -5)  { true => 0, _ => 0 / 0, };
    let _ok2 = match (-(-5) == 5)  { true => 0, _ => 0 / 0, };
    let _ok3 = match (!true  == false) { true => 0, _ => 0 / 0, };
    let _ok4 = match (!false == true)  { true => 0, _ => 0 / 0, };
    let _ok5 = match (!!true  == true)  { true => 0, _ => 0 / 0, };
    let _ok6 = match (!!false == false) { true => 0, _ => 0 / 0, };
    let f = -2.5;
    let _ok7 = match (f == -2.5) { true => 0, _ => 0 / 0, };
}
