fun main() {
    // Basic while loop.
    mut i = 0;
    while (i < 5) { i = i + 1; }
    let _ok1 = match (i == 5) { true => 0, _ => 0 / 0, };
    // Break exits the loop.
    mut j = 0;
    while (true) {
        if (j == 3) { break; }
        j = j + 1;
    }
    let _ok2 = match (j == 3) { true => 0, _ => 0 / 0, };
    // False initial condition: body never executes.
    mut ran = 0;
    while (false) { ran = 1; }
    let _ok3 = match (ran == 0) { true => 0, _ => 0 / 0, };
}
