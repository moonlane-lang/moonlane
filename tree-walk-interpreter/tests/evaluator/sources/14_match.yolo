enum Coin { Heads, Tails }

fun main() {
    // Literal pattern.
    let r1 = match 2 { 1 => 10, 2 => 20, _ => 30, };
    let _ok1 = match (r1 == 20) { true => 0, _ => 0 / 0, };
    // Wildcard.
    let r2 = match 99 { 1 => 1, _ => 0, };
    let _ok2 = match (r2 == 0) { true => 0, _ => 0 / 0, };
    // Binding.
    let r3 = match 7 { n => n + 1, };
    let _ok3 = match (r3 == 8) { true => 0, _ => 0 / 0, };
    // Enum variant.
    let c = Coin::Tails;
    let r4 = match c { Coin::Heads => 1, Coin::Tails => 2, };
    let _ok4 = match (r4 == 2) { true => 0, _ => 0 / 0, };
    // Guard.
    let r5 = match 5 { n if n < 3 => 0, n if n < 7 => 1, _ => 2, };
    let _ok5 = match (r5 == 1) { true => 0, _ => 0 / 0, };
    // Nope pattern.
    let maybe: Perhaps<Int> = nope;
    let r6 = match maybe { nope => 1, _ => 0, };
    let _ok6 = match (r6 == 1) { true => 0, _ => 0 / 0, };
    // String literal pattern.
    let r7 = match "hello" { "world" => 1, "hello" => 2, _ => 3, };
    let _ok7 = match (r7 == 2) { true => 0, _ => 0 / 0, };
    // Bool literal patterns.
    let _ok8 = match true  { true => 0, _ => 0 / 0, };
    let _ok9 = match false { false => 0, _ => 0 / 0, };
    // Float literal pattern.
    let r8 = match 3.14 { 1.0 => 1, 3.14 => 2, _ => 3, };
    let _ok10 = match (r8 == 2) { true => 0, _ => 0 / 0, };
    // Tuple pattern — binds elements.
    let pair: (Int, Int) = (3, 4);
    let r9 = match pair { (a, b) => a + b, };
    let _ok11 = match (r9 == 7) { true => 0, _ => 0 / 0, };
    // Nested tuple pattern.
    let nested: (Int, (Int, Int)) = (1, (2, 3));
    let r10 = match nested { (a, (b, c)) => a + b + c, };
    let _ok12 = match (r10 == 6) { true => 0, _ => 0 / 0, };
    // First arm wins when multiple arms match.
    let r11 = match 42 { first => 1, second => 2, };
    let _ok13 = match (r11 == 1) { true => 0, _ => 0 / 0, };
    // Guard uses the bound variable.
    let r12 = match 10 { n if n > 5 => n * 2, _ => 0, };
    let _ok14 = match (r12 == 20) { true => 0, _ => 0 / 0, };
    // Guard failure falls through to the next arm.
    let r13 = match 5 { n if n == 1 => 10, n if n == 5 => 50, _ => 0, };
    let _ok15 = match (r13 == 50) { true => 0, _ => 0 / 0, };
}
