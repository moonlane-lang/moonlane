// Mutual recursion.
fun is_even(n: Int) -> Bool {
    if (n == 0) { true } else { is_odd(n - 1) }
}
fun is_odd(n: Int) -> Bool {
    if (n == 0) { false } else { is_even(n - 1) }
}
// Early return via return statement (not tail expression).
fun sign(n: Int) -> Int {
    if (n > 0) { return 1; }
    if (n < 0) { return -1; }
    return 0;
}
// Function that calls a builtin.
fun greet(name: String) -> String {
    string_concat("hello ", name)
}
// Function stored in a variable and called through it.
fun double(x: Int) -> Int { x * 2 }

fun main() {
    // Mutual recursion.
    let _ok1 = match (is_even(4)) { true => 0, _ => 0 / 0, };
    let _ok2 = match (is_odd(3))  { true => 0, _ => 0 / 0, };
    let _ok3 = match (is_even(0)) { true => 0, _ => 0 / 0, };
    let _ok4 = match (is_odd(1))  { true => 0, _ => 0 / 0, };
    // Early return.
    let _ok5 = match (sign(5)  ==  1) { true => 0, _ => 0 / 0, };
    let _ok6 = match (sign(-3) == -1) { true => 0, _ => 0 / 0, };
    let _ok7 = match (sign(0)  ==  0) { true => 0, _ => 0 / 0, };
    // Calling a builtin from a user function.
    let s = greet("world");
    let _ok8 = match (s == "hello world") { true => 0, _ => 0 / 0, };
    // Call through a variable binding.
    let f = double;
    let r = f(21);
    let _ok9 = match (r == 42) { true => 0, _ => 0 / 0, };
}
