fun main() {
    let _ok1 = match (3 + 4   == 7)  { true => 0, _ => 0 / 0, };
    let _ok2 = match (10 - 3  == 7)  { true => 0, _ => 0 / 0, };
    let _ok3 = match (3 * 4   == 12) { true => 0, _ => 0 / 0, };
    let _ok4 = match (10 / 3  == 3)  { true => 0, _ => 0 / 0, };
    let _ok5 = match (10 % 3  == 1)  { true => 0, _ => 0 / 0, };
    // Division truncates toward zero (not floor).
    let _ok6 = match (7 / 2   == 3)  { true => 0, _ => 0 / 0, };
    let _ok7 = match (-7 / 2  == -3) { true => 0, _ => 0 / 0, };
    // Remainder sign follows the dividend.
    let _ok8 = match (-10 % 3  == -1) { true => 0, _ => 0 / 0, };
    let _ok9 = match (10 % -3  == 1)  { true => 0, _ => 0 / 0, };
}
