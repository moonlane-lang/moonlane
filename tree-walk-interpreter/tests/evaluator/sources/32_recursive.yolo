fun factorial(n: Int) -> Int {
    if (n <= 1) { 1 } else { n * factorial(n - 1) }
}
fun fib(n: Int) -> Int {
    if (n <= 1) { n } else { fib(n - 1) + fib(n - 2) }
}
fun main() {
    let r1 = factorial(0);
    let _ok1 = match (r1 == 1) { true => 0, _ => 0 / 0, };
    let r2 = factorial(5);
    let _ok2 = match (r2 == 120) { true => 0, _ => 0 / 0, };
    let r3 = fib(0);
    let _ok3 = match (r3 == 0) { true => 0, _ => 0 / 0, };
    let r4 = fib(10);
    let _ok4 = match (r4 == 55) { true => 0, _ => 0 / 0, };
}
