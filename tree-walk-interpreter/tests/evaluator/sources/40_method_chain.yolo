struct Vec2 { x: Int, y: Int }

impl Vec2 {
    fun add(self, other: Vec2) -> Vec2 {
        Vec2 { x: self.x + other.x, y: self.y + other.y }
    }
    fun scale(self, factor: Int) -> Vec2 {
        Vec2 { x: self.x * factor, y: self.y * factor }
    }
    fun negate(self) -> Vec2 {
        Vec2 { x: -self.x, y: -self.y }
    }
    fun length_sq(self) -> Int {
        self.x * self.x + self.y * self.y
    }
    fun dot(self, other: Vec2) -> Int {
        self.x * other.x + self.y * other.y
    }
}

fun main() {
    let a = Vec2 { x: 1, y: 2 };
    let b = Vec2 { x: 3, y: 4 };
    // Two-level chain: add then scale.  (1+3, 2+4)=(4,6) * 2 = (8,12)
    let c = a.add(b).scale(2);
    let _ok1 = match (c.x == 8)  { true => 0, };
    let _ok2 = match (c.y == 12) { true => 0, };
    // Three-level chain ending in a scalar.  (8,12).length_sq = 64+144 = 208
    let lsq = a.add(b).scale(2).length_sq();
    let _ok3 = match (lsq == 208) { true => 0, };
    // Chain ending in dot product.  a.scale(3)=(3,6); (3,6)·(3,4)=9+24=33
    let d = a.scale(3).dot(b);
    let _ok4 = match (d == 33) { true => 0, };
    // Single-method chain.
    let neg = a.negate();
    let _ok5 = match (neg.x == -1) { true => 0, };
    let _ok6 = match (neg.y == -2) { true => 0, };
    // Intermediate binding, then further chain.  a.add(b)=(4,6); length_sq=16+36=52
    let mid = a.add(b);
    let _ok7 = match (mid.length_sq() == 52) { true => 0, };
    // Chain via intermediate: negate then add.  neg=(-1,-2); neg.add(a)=(0,0)
    let zero = neg.add(a);
    let _ok8 = match (zero.length_sq() == 0) { true => 0, };
}
