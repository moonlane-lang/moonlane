fun main() {
    // Basic counting.
    mut sum = 0;
    for (mut i = 0; i < 5; i += 1) { sum += i; }
    let _ok1 = match (sum == 10) { true => 0, _ => 0 / 0, };
    // Break exits the loop.
    mut count = 0;
    for (mut i = 0; i < 100; i += 1) {
        if (i == 5) { break; }
        count += 1;
    }
    let _ok2 = match (count == 5) { true => 0, _ => 0 / 0, };
    // Continue still executes the step expression.
    mut c2 = 0;
    for (mut i = 0; i < 5; i += 1) {
        if (i == 2) { continue; }
        c2 += 1;
    }
    let _ok3 = match (c2 == 4) { true => 0, _ => 0 / 0, };
}
