// Closure returning a closure (currying).
fun add_n(n: Int) -> fun(Int) -> Int {
    fun(x: Int) -> Int { n + x }
}
fun scale_then_add(factor: Int) -> fun(Int) -> fun(Int) -> Int {
    fun(base: Int) -> fun(Int) -> Int {
        fun(x: Int) -> Int { factor * base + x }
    }
}

fun main() {
    // Basic closure returned from function.
    let add3 = add_n(3);
    let add7 = add_n(7);
    let _ok1 = match (add3(10) == 13) { true => 0, _ => 0 / 0, };
    let _ok2 = match (add7(10) == 17) { true => 0, _ => 0 / 0, };
    // Two independently-created closures do not share captured state.
    let _ok3 = match (add3(0) == 3) { true => 0, _ => 0 / 0, };
    let _ok4 = match (add7(0) == 7) { true => 0, _ => 0 / 0, };
    // Two-level currying: scale_then_add(2)(5)(3) = 2*5+3 = 13
    let m2    = scale_then_add(2);
    let m2b5  = m2(5);
    let _ok5  = match (m2b5(3)  == 13) { true => 0, _ => 0 / 0, };
    let _ok6  = match (m2b5(7)  == 17) { true => 0, _ => 0 / 0, };
    // Different base produces a different inner closure.
    let m2b10 = m2(10);
    let _ok7  = match (m2b10(0) == 20) { true => 0, _ => 0 / 0, };
    // Array of closures — each captures a different value.
    let fns = [add_n(1), add_n(2), add_n(3)];
    let _ok8  = match (fns[0](10) == 11) { true => 0, _ => 0 / 0, };
    let _ok9  = match (fns[1](10) == 12) { true => 0, _ => 0 / 0, };
    let _ok10 = match (fns[2](10) == 13) { true => 0, _ => 0 / 0, };
    // Closure created per loop iteration — each iteration captures a snapshot of i.
    // Use the closure immediately inside the loop instead of storing in an array.
    mut sum = 0;
    mut i = 0;
    while (i < 5) {
        let adder = add_n(i);
        sum += adder(0);   // adder(0) == i, so sum accumulates 0+1+2+3+4 = 10
        i += 1;
    }
    let _ok11 = match (sum == 10) { true => 0, _ => 0 / 0, };
    // Closures stored in array via literal (type inferred from elements).
    let adders = [add_n(10), add_n(20), add_n(30)];
    let _ok12 = match (adders[0](1) == 11) { true => 0, _ => 0 / 0, };
    let _ok13 = match (adders[2](1) == 31) { true => 0, _ => 0 / 0, };
}
