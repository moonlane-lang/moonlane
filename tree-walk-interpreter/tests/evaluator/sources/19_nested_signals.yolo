fun main() {
    // Break only breaks the innermost loop.
    mut outer_ran = 0;
    loop {
        while (true) { break; }
        outer_ran = 1;
        break;
    }
    let _ok1 = match (outer_ran == 1) { true => 0, _ => 0 / 0, };
    // Each outer iteration starts with a fresh inner scope.
    mut total = 0;
    mut k = 0;
    loop {
        k += 1;
        if (k > 3) { break; }
        mut j = 0;
        loop {
            j += 1;
            if (j >= 2) { break; }
        }
        total += j;
    }
    let _ok2 = match (total == 6) { true => 0, _ => 0 / 0, };
    // Return propagates through nested loops — must be the last statement.
    loop {
        loop { return; }
        let _never = 1 / 0;
    }
}
